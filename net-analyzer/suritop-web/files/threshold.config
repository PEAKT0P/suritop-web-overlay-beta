# Suppress noisy QUIC alerts
suppress gen_id 1, sig_id 2210050
suppress gen_id 1, sig_id 2210054

# Suppress STUN (Nextcloud Talk TURN server)
#suppress gen_id 1, sig_id 2027865
suppress gen_id 1, sig_id 2027866
suppress gen_id 1, sig_id 2027867

# Suppress non-DNS on port 53
suppress gen_id 1, sig_id 2067113

# Rate-limit SSH scan alerts
threshold gen_id 1, sig_id 2003068, type limit, track by_src, count 1, seconds 60

# Suppress Telegram (our bot/service)
suppress gen_id 1, sig_id 2033966
suppress gen_id 1, sig_id 2033967

# Suppress QUIC decrypt (normal encrypted traffic)
suppress gen_id 1, sig_id 2231000
suppress gen_id 1, sig_id 2231001

# Suppress Applayer Wrong direction (NAT artifact)
suppress gen_id 1, sig_id 2260001

# Suppress ip-api lookups (our stats_collector)
suppress gen_id 1, sig_id 2054141
suppress gen_id 1, sig_id 2022082
suppress gen_id 1, sig_id 2013031

# Suppress TLS invalid record (scan noise)
suppress gen_id 1, sig_id 2230002

# Suppress STREAM noise (NAT/protocol artifacts, not attacks)
suppress gen_id 1, sig_id 2210044
suppress gen_id 1, sig_id 2210055
suppress gen_id 1, sig_id 2210042
suppress gen_id 1, sig_id 2210020
suppress gen_id 1, sig_id 2210026
suppress gen_id 1, sig_id 2210016
suppress gen_id 1, sig_id 2221010

# Suppress SMB internal traffic
suppress gen_id 1, sig_id 2225006
